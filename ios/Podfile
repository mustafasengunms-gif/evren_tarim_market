# Flutter araçlarını dahil etmek için tam yolu manuel olarak belirtiyoruz
podhelper_path = File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)
require podhelper_path

platform :ios, '15.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Eğer podhelper yüklendiyse bu metot çalışacaktır
  if respond_to?(:flutter_install_all_ios_pods)
    flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Metot tanımlı mı diye kontrol ederek hata patlamasını önlüyoruz
    if respond_to?(:flutter_additional_ios_build_settings)
      flutter_additional_ios_build_settings(target)
    end

    # Apple Silicon (M1/M2) ve güncel Xcode uyumluluğu için ek ayar
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end