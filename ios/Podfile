# Flutter'ın kendi yardımcı dosyasını dahil ediyoruz
podhelper_path = File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)
require podhelper_path

platform :ios, '15.0'

target 'Runner' do
  # Firebase ve modül hatalarını önlemek için kritik ayar
  use_frameworks! :linkage => :static
  use_modular_headers!

  # Flutter paketlerini yükle (Bu satır silinmemelidir!)
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Flutter ayarlarını güvenli bir şekilde uygula
    if defined?(flutter_additional_ios_build_settings)
      flutter_additional_ios_build_settings(target)
    end

    target.build_configurations.each do |config|
      # Sürüm uyumluluğu zorlaması
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # Xcode 15+ Sandbox hatası koruması
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
    end
  end
end