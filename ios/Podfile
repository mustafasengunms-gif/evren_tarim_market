# Podfile
platform :ios, '15.0'

# Flutter'ın kendi yardımcı dosyasını dahil ediyoruz
target_path = File.join(File.dirname(File.realpath(__FILE__)), '..', '..', 'flutter', 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
# Eğer üstteki yol bulamazsa standart yolu dene
unless File.exist?(target_path)
  target_path = File.expand_path(File.join(File.dirname(__FILE__), 'Flutter', 'podhelper.rb'))
end
require target_path

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end