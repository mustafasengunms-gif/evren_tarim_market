# Flutter'ın standart yardımcı dosyasını içeri aktarır
target_path = File.expand_path('..', __FILE__)
source_path = File.join(target_path, 'Flutter', 'podhelper.rb')
load source_path

platform :ios, '15.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Flutter'ın kendi podlarını yüklemesini sağlar
  flutter_install_all_ios_pods target_path
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # Simülatör ve işlemci mimarisi hatalarını engellemek için
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386 arm64'
    end
  end
end