# Podfile - Evren Tarım Market iOS Yapılandırması
platform :ios, '13.0'

# Flutter'ın kendi yardımcı dosyasını dahil ediyoruz
load File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'podhelper.rb')

target 'Runner' do
  # Modül hatalarını çözen kritik satırlar
  use_frameworks! :linkage => :static
  use_modular_headers!

  # Kütüphaneleri buraya yüklüyoruz
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Flutter'ın ek ayarlarını her hedef için uygula
    flutter_additional_ios_build_settings(target) if respond_to?(:flutter_additional_ios_build_settings)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      # Firestore ve Firebase için modül desteğini açıyoruz
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      config.build_settings['DEFINES_MODULE'] = 'YES'
    end
  end
end